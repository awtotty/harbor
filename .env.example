# Copy to .env and change this before running on any always-on host.
HARBOR_PASSWORD=change-me
HARBOR_PRODUCTION=false

# Bind localhost by default. For Tailscale-only access on a VPS, set these to the
# server's Tailscale IPv4 address, or keep localhost and use an SSH tunnel.
HARBOR_BIND_HOST=127.0.0.1
HARBOR_PORT=8080
# Optional dev-server port range for apps started by the agent inside Docker.
# Set to your Tailscale IP for Tailnet access, or leave localhost-only.
HARBOR_DEV_BIND_HOST=127.0.0.1
HARBOR_CONFIG_DIR=/config
HARBOR_WORKSPACE_DIR=/workspace
HARBOR_TERMINAL_USER=agent

# Optional external updater sidecar. Generate a strong random token before enabling the updater profile.
HARBOR_UPDATER_TOKEN=
HARBOR_UPDATER_URL=http://harbor-updater:8787
PI_CODING_AGENT_DIR=/config/pi-agent
PI_CODING_AGENT_SESSION_DIR=/config/sessions
